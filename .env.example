# === Required ===
OPENAI_API_KEY=sk-...

# === TTS (pick one) ===
TTS_PROVIDER=openai
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# === Google Calendar (optional — falls back to local SQLite) ===
# GOOGLE_CREDENTIALS_PATH=./credentials.json
# GOOGLE_CALENDAR_ID=primary

# === Weather (OpenWeatherMap — free tier) ===
# WEATHER_API_KEY=...
DEFAULT_LOCATION=New York,US

# === Twilio (for emergency calls — not your part) ===
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+1...
# EMERGENCY_CONTACT_NUMBER=+1...

# === App Config ===
USER_NAME=friend
